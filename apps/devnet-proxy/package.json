{
  "name": "@partylayer/devnet-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "DevNet gateway: server-side ledger and registry access for the tokenization and dvp verticals, built on the official Canton wallet sdk. The browser never holds a ledger credential.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node scripts/devnet-smoke.mjs",
    "test": "tsx --test src/mapping.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@canton-network/wallet-sdk": "1.4.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
